import "../common/config"
import "auth"
import "products"

POST {{base_url}}/carts/add
Authorization: Bearer {{access_token}}
Content-Type: application/json
{
    "userId": {{user_id}},
    "products": [
        {
            "id": {{product_id}},
            "quantity": 2
        }
    ]
}
HTTP 201
[Captures]
cart_id: jsonpath "$.id"
cart_total: jsonpath "$.total"
